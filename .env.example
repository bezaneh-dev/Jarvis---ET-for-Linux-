# Security
ASSISTANT_TOKEN=change-me

# Runtime
REFRESH_INTERVAL=1.0
CPU_THRESHOLD=90
MEMORY_THRESHOLD=90
TOOL_TIMEOUT_SECONDS=8

# AI routing
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
# Free cloud option (optional): https://console.groq.com/keys
CLOUD_PROVIDER=none
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
AI_ROUTE_MODE=local

# Greeting behavior
GREETING_ENABLED=true
ASSISTANT_NAME=Jarvis
USER_NAME=Boss

# Speech-to-text quality
STT_MODE=hybrid
STT_LANGUAGE=en
FASTER_WHISPER_MODEL=small
OPENAI_STT_MODEL=whisper-1

# Text-to-speech quality
TTS_MODE=hybrid
PIPER_BIN=piper
# Free piper voices: https://huggingface.co/rhasspy/piper-voices
PIPER_MODEL_PATH=
PIPER_SPEAKER_ID=0

# Command safety
ALLOWED_COMMANDS=ls,pwd,whoami,date,uptime,free,df,ps
